{
  "permissions": {
    "allow": [
      "Bash(npx tsc:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/auditor-no-code.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/debugger-no-code.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/critic-no-code.sh nimbus"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/critic-no-source-read.sh nimbus"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/auditor-no-mutating-bash.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/worker-no-orchestration-bash.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/lightweight-no-orchestration-bash.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/debugger-no-orchestration-bash.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/critic-no-orchestration-bash.sh nimbus"
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/auditor-no-editing-subagents.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/lightweight-no-editing-subagents.sh nimbus"
          },
          {
            "type": "command",
            "command": "./.claude/hooks/debugger-no-editing-subagents.sh nimbus"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/auditor-worker-notify.sh nimbus"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "logout|prompt_input_exit|bypass_permissions_disabled|other",
        "hooks": [
          {
            "type": "command",
            "command": "./.claude/hooks/auditor-shutdown.sh nimbus"
          }
        ]
      }
    ]
  }
}
